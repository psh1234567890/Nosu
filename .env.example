API_PORT=4000
API_HOST=127.0.0.1
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DEBATE_CLOCK_TICK_MS=1000
# Optional. Leave blank to use ./data/state.json. Smoke scripts use a temp DATA_DIR.
# DATA_DIR=./data

# Defaults to true when NODE_ENV=production. Set true to serve dist/ from Express.
SERVE_STATIC_APP=false

# Release identity shown in /api/health, /api/status, and launch evidence.
# Production release env must set a real git SHA and ISO build time.
RELEASE_VERSION=0.1.0
RELEASE_COMMIT=local
RELEASE_CHANNEL=development
RELEASE_BUILD_TIME=

# Dev-only convenience switches. Defaults are true in development and false when NODE_ENV=production.
ENABLE_DEMO_AUTH=true
ENABLE_OPEN_STATE_WRITE=true

RATE_LIMIT_AUTH_WINDOW_SECONDS=600
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_SOCIAL_MAX=12
RATE_LIMIT_DEMO_MAX=40
RATE_LIMIT_PHONE_REQUEST_MAX=5
RATE_LIMIT_PHONE_VERIFY_MAX=10
RATE_LIMIT_PASSWORD_MAX=6
RATE_LIMIT_WRITE_WINDOW_SECONDS=60
RATE_LIMIT_MESSAGE_MAX=30
RATE_LIMIT_REPORT_MAX=10
MAX_AUDIT_LOGS=300

PHONE_CODE_TTL_SECONDS=300
PHONE_CODE_RESEND_SECONDS=30
PHONE_CODE_MAX_ATTEMPTS=5
# Defaults to true when NODE_ENV=production. Keep false only while developing without an SMS provider.
PHONE_CODE_HIDE_DEBUG=false
PHONE_CODE_SMS_TEMPLATE=[노수베스트] 인증번호는 {{code}}입니다. {{ttlMinutes}}분 안에 입력해주세요.

# dev: local development only. solapi: sends real Korean SMS through SOLAPI.
SMS_PROVIDER=dev
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_SENDER_NUMBER=01000000000
SOLAPI_API_BASE_URL=https://api.solapi.com

OPENAI_API_KEY=your-openai-api-key
OPENAI_JUDGE_MODEL=gpt-4o-mini
# Set true for deterministic local/dev smoke runs that should not call OpenAI.
AI_JUDGE_FORCE_LOCAL=false

# Supabase is optional. If these are omitted, the API uses data/state.json.
# Use a server-only key. Never expose this key in frontend code.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_TABLE_PREFIX=nb_
SUPABASE_PROFILE_PHOTO_BUCKET=profile-photos

# snapshot: stores the whole MVP state in nb_app_state jsonb.
# normalized: reads/writes prefixed service tables such as nb_users, nb_rooms, nb_channels, nb_votes.
SUPABASE_STORAGE_MODE=snapshot
SUPABASE_STATE_TABLE=nb_app_state
APP_STATE_ID=default
